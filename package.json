{
  "name": "@fantabeach/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm run db:generate",
    "build": "dotenvx run -f .env -- tsc",
    "predev": "npm run db:generate",
    "dev": "dotenvx run -f .env -- tsx watch src/main.ts",
    "start": "dotenvx run -f .env -- node dist/main.js",
    "pretypecheck": "npm run db:generate",
    "typecheck": "tsc --noEmit",
    "pm:generate": "node scripts/generate-postman.js",
    "db:generate": "dotenvx run -f .env -- prisma generate",
    "db:push": "dotenvx run -f .env -- prisma db push",
    "db:migrate": "dotenvx run -f .env -- prisma migrate dev",
    "db:studio": "dotenvx run -f .env -- prisma studio",
    "db:seed": "dotenvx run -f .env -- prisma db seed"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "stripe": "^20.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/nodemailer": "^7.0.11",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
