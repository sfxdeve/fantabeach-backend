generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

// ─── User & Auth ─────────────────────────────────────────────────────────────
enum Role {
  ADMIN
  USER
}

enum OtpPurpose {
  VERIFY_EMAIL
  RESET_PASSWORD
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  passHash   String
  name       String
  role       Role     @default(USER)
  isVerified Boolean  @default(false)
  isBlocked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sessions       Session[]
  otps           Otp[]
  leagues        League[]
  memberships    LeagueMembership[]
  fantasyTeams   FantasyTeam[]
  wallet         Wallet?
  adminAuditLogs AuditLog[]
}

model Session {
  id        String   @id @default(uuid())
  userAgent String   @default("")
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        String     @id @default(uuid())
  purpose   OtpPurpose
  codeHash  String
  expiresAt DateTime
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  before    Json?
  after     Json?
  entityId  String?
  entity    String
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminId String
  admin   User   @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

// ─── Championship & Tournament (athletes, matches) ───────────────────────────
enum Gender {
  MALE
  FEMALE
}

enum TournamentStatus {
  UPCOMING
  REGISTRATION_OPEN
  LOCKED
  ONGOING
  COMPLETED
}

enum EntryStatus {
  DIRECT
  QUALIFICATION
  RESERVE_1
  RESERVE_2
  RESERVE_3
}

enum MatchRound {
  QUALIFICATION_R1
  QUALIFICATION_R2
  POOL
  R12
  QF
  SF
  FINAL
  THIRD_PLACE
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CORRECTED
}

model Championship {
  id         String   @id @default(uuid())
  name       String
  gender     Gender
  seasonYear Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  athletes    Athlete[]
  tournaments Tournament[]
  leagues     League[]
}

model Athlete {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  gender    Gender
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  championshipId String
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)

  tournamentPairsA TournamentPair[]     @relation("TournamentPairAthleteA")
  tournamentPairsB TournamentPair[]     @relation("TournamentPairAthleteB")
  rosterEntries    RosterEntry[]
  lineupSlots      LineupSlot[]
  matchPoints      AthleteMatchPoints[]
}

model Tournament {
  id           String           @id @default(uuid())
  status       TournamentStatus @default(UPCOMING)
  lineupLockAt DateTime?
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  championshipId String
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)

  pairs             TournamentPair[]
  matches           Match[]
  lineups           Lineup[]
  gameweekStandings GameweekStanding[]
}

model TournamentPair {
  id          String      @id @default(uuid())
  entryStatus EntryStatus
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  athleteAId String
  athleteA   Athlete @relation("TournamentPairAthleteA", fields: [athleteAId], references: [id], onDelete: Restrict)

  athleteBId String
  athleteB   Athlete @relation("TournamentPairAthleteB", fields: [athleteBId], references: [id], onDelete: Restrict)

  matchesAsPairA Match[] @relation("MatchPairA")
  matchesAsPairB Match[] @relation("MatchPairB")
  matchesWon     Match[] @relation("MatchWinnerPair")

  @@unique([tournamentId, athleteAId, athleteBId])
}

model Match {
  id          String      @id @default(uuid())
  set1A       Int?
  set1B       Int?
  set2A       Int?
  set2B       Int?
  set3A       Int?
  set3B       Int?
  round       MatchRound
  status      MatchStatus @default(SCHEDULED)
  scheduledAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  pairAId String
  pairA   TournamentPair @relation("MatchPairA", fields: [pairAId], references: [id], onDelete: Restrict)

  pairBId String
  pairB   TournamentPair @relation("MatchPairB", fields: [pairBId], references: [id], onDelete: Restrict)

  winnerPairId String?
  winnerPair   TournamentPair? @relation("MatchWinnerPair", fields: [winnerPairId], references: [id], onDelete: SetNull)

  athletePoints AthleteMatchPoints[]
}

model AthleteMatchPoints {
  id          String   @id @default(uuid())
  basePoints  Float    @default(0)
  bonusPoints Float    @default(0)
  totalPoints Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  athleteId String
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
}

// ─── League & Fantasy ─────────────────────────────────────────────────────────
enum LeagueStatus {
  OPEN
  ONGOING
  COMPLETED
}

enum LineupRole {
  STARTER
  BENCH
}

model League {
  id           String       @id @default(uuid())
  name         String
  rosterSize   Int
  startersSize Int
  status       LeagueStatus @default(OPEN)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  championshipId String
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)

  memberships  LeagueMembership[]
  fantasyTeams FantasyTeam[]
  standings    GameweekStanding[]
}

model LeagueMembership {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  leagueId String
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
}

model FantasyTeam {
  id          String   @id @default(uuid())
  name        String
  totalPoints Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leagueId String
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roster    RosterEntry[]
  lineups   Lineup[]
  standings GameweekStanding[]
}

model RosterEntry {
  id         String   @id @default(uuid())
  acquiredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fantasyTeamId String
  fantasyTeam   FantasyTeam @relation(fields: [fantasyTeamId], references: [id], onDelete: Cascade)

  athleteId String
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Restrict)
}

model Lineup {
  id        String    @id @default(uuid())
  lockedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  fantasyTeamId String
  fantasyTeam   FantasyTeam @relation(fields: [fantasyTeamId], references: [id], onDelete: Cascade)

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  slots LineupSlot[]
}

model LineupSlot {
  id              String     @id @default(uuid())
  role            LineupRole
  benchOrder      Int?
  isSubstitutedIn Boolean    @default(false)
  pointsScored    Float      @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  lineupId String
  lineup   Lineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)

  athleteId String
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Restrict)
}

model GameweekStanding {
  id               String   @id @default(uuid())
  gameweekPoints   Float    @default(0)
  cumulativePoints Float    @default(0)
  rank             Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  leagueId String
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  fantasyTeamId String
  fantasyTeam   FantasyTeam @relation(fields: [fantasyTeamId], references: [id], onDelete: Cascade)

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

// ─── Wallet & Credits ───────────────────────────────────────────────────────
enum CreditTransactionType {
  PURCHASE
  SPEND
  BONUS
  REFUND
}

enum CreditTransactionSource {
  ADMIN
  SYSTEM
  STRIPE
}

model Wallet {
  id        String   @id @default(uuid())
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions CreditTransaction[]
}

model CreditPack {
  id            String   @id @default(uuid())
  name          String
  credits       Int
  stripePriceId String   @unique
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CreditTransaction {
  id           String                  @id @default(uuid())
  type         CreditTransactionType
  source       CreditTransactionSource
  amount       Float
  balanceAfter Float
  meta         Json?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}
